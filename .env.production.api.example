NODE_ENV=production
API_PORT=4000
API_PUBLIC_URL=https://api.yourdomain.com
WEB_APP_URL=https://app.yourdomain.com
CORS_ORIGIN=https://app.yourdomain.com

# AWS RDS PostgreSQL. Use sslmode=require when RDS requires TLS.
DATABASE_URL=postgresql://app_user:strong_password@your-rds-endpoint.rds.amazonaws.com:5432/social_scheduler?schema=public&sslmode=require

# AWS ElastiCache Redis. Use rediss:// when in-transit encryption is required.
REDIS_URL=rediss://your-elasticache-primary-endpoint.cache.amazonaws.com:6379

JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_EXPIRES_IN=7d
TOKEN_ENCRYPTION_KEY=replace-with-at-least-32-random-bytes

X_CLIENT_ID=
X_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_LOGIN_CONFIG_ID=
FACEBOOK_OAUTH_SCOPES=public_profile
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
